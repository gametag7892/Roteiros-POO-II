<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <variable name="LayoutCustomizado" value="${longdate} | ${level:uppercase=true} | ${message} ${exception:format=toString}" />

  <targets>
    <target xsi:type="File" name="arquivoLog" fileName="${basedir}/logs/app-${shortdate}.log" layout="${LayoutCustomizado}" />
    
    <target xsi:type="Console" name="consoleLog" layout="${LayoutCustomizado}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="arquivoLog,consoleLog" />
  </rules>
</nlog>